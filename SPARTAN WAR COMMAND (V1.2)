// ==UserScript==
// @name         Spartan War Command v1.1
// @namespace    torn.war.intel
// @version      v1.1
// @description  PDA optimized ranked war intelligence system (stable UI fix)
// @match        https://www.torn.com/factions.php*
// @run-at       document-end
// ==/UserScript==

(function () {

    // ================= API SYSTEM =================
    const API_STORAGE_KEY = "spartan_api_key";

    const getApiKey = () => localStorage.getItem(API_STORAGE_KEY) || "";
    const setApiKey = (k) => localStorage.setItem(API_STORAGE_KEY, k.trim());

    let API_KEY = getApiKey();

    // ================= STATE =================
    const STATE_KEY = "spartan_state_v1.1";

    let state = {
        x: 20,
        y: 80,
        compact: false
    };

    let enemyRoster = {};
    let cache = {};
    let search = "";
    let warActive = false;

    const now = () => Math.floor(Date.now() / 1000);

    function fmt(t) {
        t = Math.max(0, t);
        return `${Math.floor(t / 60)}:${(t % 60).toString().padStart(2, "0")}`;
    }

    function copy(text) {
        navigator.clipboard?.writeText(text).catch(() => {
            const ta = document.createElement("textarea");
            ta.value = text;
            document.body.appendChild(ta);
            ta.select();
            document.execCommand("copy");
            ta.remove();
        });
    }

    // load state
    try {
        const saved = JSON.parse(localStorage.getItem(STATE_KEY));
        if (saved) state = saved;
    } catch {}

    function saveState() {
        localStorage.setItem(STATE_KEY, JSON.stringify(state));
    }

    // ================= UI =================
    const panel = document.createElement("div");

    Object.assign(panel.style, {
        position: "fixed",
        top: state.y + "px",
        left: state.x + "px",
        width: "280px",
        background: "#0f0f0f",
        color: "#fff",
        border: "1px solid #333",
        borderRadius: "8px",
        padding: "6px",
        zIndex: 999999,
        fontSize: "10px",
        fontFamily: "Arial",
        userSelect: "none",
        touchAction: "none",
        willChange: "transform,width,height",
        contain: "layout paint"
    });

    panel.innerHTML = `
        <div style="display:flex;gap:6px;align-items:center;margin-bottom:6px;">

            <div id="drag" style="width:46px;height:46px;background:#333;border-radius:8px;
                display:flex;align-items:center;justify-content:center;font-size:18px;cursor:grab;">⋮⋮</div>

            <div id="toggle" style="width:46px;height:46px;background:#222;border-radius:8px;
                display:flex;align-items:center;justify-content:center;font-size:16px;cursor:pointer;">▣</div>

            <div id="settings" style="width:46px;height:46px;background:#222;border-radius:8px;
                display:flex;align-items:center;justify-content:center;font-size:16px;cursor:pointer;">⚙️</div>

            <div style="flex:1;text-align:center;font-weight:bold;background:#111;padding:6px;border-radius:6px;">
                SPARTAN WAR
            </div>
        </div>

        <input id="search" placeholder="Search enemy..."
            style="width:85%;padding:4px;font-size:9px;margin-bottom:6px;border-radius:4px;border:none;">

        <div id="list"></div>
    `;

    document.body.appendChild(panel);

    const drag = document.getElementById("drag");
    const toggle = document.getElementById("toggle");
    const settings = document.getElementById("settings");
    const list = document.getElementById("list");
    const searchBox = document.getElementById("search");

    // ================= SETTINGS =================
    settings.onclick = () => {
        const key = prompt("Enter Torn API Key:", getApiKey());
        if (!key) return;

        setApiKey(key);
        API_KEY = key.trim();

        alert("API key saved.");
    };

    // ================= SEARCH =================
    searchBox.oninput = e => search = e.target.value.toLowerCase();

    // ================= TOGGLE (FIXED) =================
    toggle.onclick = () => {
        state.compact = !state.compact;

        if (state.compact) {
            searchBox.style.display = "none";
            list.style.display = "none";

            panel.style.width = "70px";
            panel.style.height = "70px";
            panel.style.overflow = "hidden";

            toggle.textContent = "▢";
        } else {
            searchBox.style.display = "block";
            list.style.display = "block";

            panel.style.width = "280px";
            panel.style.height = "auto";
            panel.style.overflow = "visible";

            toggle.textContent = "▣";
        }

        saveState();
    };

    // ================= DRAG =================
    let dragging = false, ox = 0, oy = 0;

    drag.onpointerdown = e => {
        dragging = true;
        const r = panel.getBoundingClientRect();
        ox = e.clientX - r.left;
        oy = e.clientY - r.top;
        panel.setPointerCapture(e.pointerId);
    };

    panel.onpointermove = e => {
        if (!dragging) return;

        state.x = e.clientX - ox;
        state.y = e.clientY - oy;

        panel.style.left = state.x + "px";
        panel.style.top = state.y + "px";
    };

    panel.onpointerup = () => {
        dragging = false;
        saveState();
    };

    // ================= WAR FETCH =================
    async function loadWar() {
        if (!API_KEY) return false;

        try {
            const r = await fetch(`https://api.torn.com/faction/?selections=rankedwars&key=${API_KEY}`);
            const d = await r.json();

            warActive = false;
            enemyRoster = {};

            if (!d?.rankedwar) return false;

            const f = d.rankedwar.factions;
            const myId = d.rankedwar.faction_id || f.attacking_faction.id;

            const enemyId =
                f.attacking_faction.id === myId
                    ? f.defending_faction.id
                    : f.attacking_faction.id;

            const r2 = await fetch(`https://api.torn.com/faction/${enemyId}?selections=basic&key=${API_KEY}`);
            const d2 = await r2.json();

            enemyRoster = d2.members || {};
            warActive = true;

            return true;

        } catch {
            return false;
        }
    }

    // ================= MAIN LOOP =================
    async function loop() {

        if (!API_KEY) {
            list.innerHTML = `
                <div style="color:#ff5555;text-align:center;">
                    ⚠️ API NOT SET<br><br>
                    Click ⚙️ to configure
                </div>
            `;
            setTimeout(loop, 3000);
            return;
        }

        await loadWar();

        const t = now();
        const output = [];

        for (const id in enemyRoster) {

            const name = enemyRoster[id].name;

            if (search && !name.toLowerCase().includes(search)) continue;

            try {

                if (!cache[id] || t - cache[id].t > 60) {
                    const r = await fetch(`https://api.torn.com/user/${id}?selections=profile&key=${API_KEY}`);
                    const d = await r.json();

                    if (!d.status) continue;

                    cache[id] = {
                        name,
                        until: d.status.until,
                        state: d.status.state,
                        t
                    };
                }

                const c = cache[id];
                if (c.state !== "Hospital") continue;

                const time = c.until - t;
                if (time <= 0) continue;

                output.push({ id, name, time });

            } catch {}
        }

        output.sort((a,b) => a.time - b.time);

        list.innerHTML = output.length ? output.map(o => `
            <div style="margin-bottom:6px;">
                <div style="display:flex;justify-content:space-between;">
                    <div>${o.name}</div>
                    <button data-id="${o.id}">CALL</button>
                </div>
                <div>${fmt(o.time)}</div>
            </div>
        `).join("") : `<div style="color:#aaa;">No targets</div>`;

        document.querySelectorAll("button[data-id]").forEach(btn => {
            btn.onclick = () => {
                const c = cache[btn.dataset.id];
                if (!c) return;
                copy(`${c.name} | ${fmt(c.until - now())}`);
            };
        });

        setTimeout(loop, 4000);
    }

    loop();

})();    try {
        const saved = JSON.parse(localStorage.getItem(STORAGE_KEY));
        if (saved) state = saved;
    } catch {}

    function saveState() {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
    }

    // ================= UI =================
    const panel = document.createElement("div");

    Object.assign(panel.style, {
        position: "fixed",
        top: state.y + "px",
        left: state.x + "px",
        width: "280px",
        background: "#0f0f0f",
        color: "#fff",
        border: "1px solid #333",
        borderRadius: "8px",
        padding: "6px",
        zIndex: 999999,
        fontSize: "10px",
        fontFamily: "Arial",
        userSelect: "none",
        touchAction: "none"
    });

    panel.innerHTML = `
        <div style="display:flex;gap:6px;align-items:center;margin-bottom:6px;">

            <div id="drag" style="width:46px;height:46px;background:#333;border-radius:8px;
                display:flex;align-items:center;justify-content:center;font-size:18px;cursor:grab;">⋮⋮</div>

            <div id="toggle" style="width:46px;height:46px;background:#222;border-radius:8px;
                display:flex;align-items:center;justify-content:center;font-size:16px;cursor:pointer;">▣</div>

            <div id="settings" style="width:46px;height:46px;background:#222;border-radius:8px;
                display:flex;align-items:center;justify-content:center;font-size:16px;cursor:pointer;">⚙️</div>

            <div style="flex:1;text-align:center;font-weight:bold;background:#111;padding:6px;border-radius:6px;">
                SPARTAN WAR
            </div>
        </div>

        <input id="search" placeholder="Search enemy..."
            style="width:85%;padding:4px;font-size:9px;margin-bottom:6px;border-radius:4px;border:none;">

        <div id="list"></div>
    `;

    document.body.appendChild(panel);

    const drag = document.getElementById("drag");
    const toggle = document.getElementById("toggle");
    const settings = document.getElementById("settings");
    const list = document.getElementById("list");
    const searchBox = document.getElementById("search");

    // ================= SETTINGS =================
    settings.onclick = () => {
        const newKey = prompt("Enter Torn API Key:", getApiKey());
        if (!newKey) return;
        API_KEY = newKey.trim();
        saveApiKey(API_KEY);
        alert("API key updated.");
    };

    // ================= SEARCH =================
    searchBox.oninput = e => {
        search = e.target.value.toLowerCase();
    };

    // ================= TOGGLE =================
    toggle.onclick = () => {
        state.compact = !state.compact;

        searchBox.style.display = state.compact ? "none" : "block";
        list.style.display = state.compact ? "none" : "block";

        panel.style.width = state.compact ? "80px" : "280px";
        saveState();
    };

    // ================= DRAG =================
    let dragging = false, ox = 0, oy = 0;

    drag.onpointerdown = e => {
        dragging = true;
        const r = panel.getBoundingClientRect();
        ox = e.clientX - r.left;
        oy = e.clientY - r.top;
        panel.setPointerCapture(e.pointerId);
    };

    panel.onpointermove = e => {
        if (!dragging) return;
        state.x = e.clientX - ox;
        state.y = e.clientY - oy;
        panel.style.left = state.x + "px";
        panel.style.top = state.y + "px";
    };

    panel.onpointerup = () => {
        dragging = false;
        saveState();
    };

    // ================= FETCH WAR =================
    async function loadWar() {
        try {
            const r = await fetch(`https://api.torn.com/faction/?selections=rankedwars&key=${API_KEY}`);
            const d = await r.json();

            warActive = false;
            enemyRoster = {};

            if (!d?.rankedwar) return;

            const f = d.rankedwar.factions;
            const myId = d.rankedwar.faction_id || f.attacking_faction.id;

            const enemyId =
                f.attacking_faction.id === myId
                    ? f.defending_faction.id
                    : f.attacking_faction.id;

            const r2 = await fetch(`https://api.torn.com/faction/${enemyId}?selections=basic&key=${API_KEY}`);
            const d2 = await r2.json();

            enemyRoster = d2.members || {};
            warActive = true;

        } catch {
            warActive = false;
        }
    }

    function fmt(t) {
        return `${Math.floor(t/60)}:${(t%60).toString().padStart(2,"0")}`;
    }

    // ================= MAIN LOOP =================
    async function loop() {

        await loadWar();

        const now = Math.floor(Date.now() / 1000);
        const output = [];

        const ids = Object.keys(enemyRoster);

        for (const id of ids) {

            const name = enemyRoster[id].name;

            if (search && !name.toLowerCase().includes(search)) continue;

            try {
                if (!cache[id] || now - cache[id].t > 60) {
                    const r = await fetch(`https://api.torn.com/user/${id}?selections=profile&key=${API_KEY}`);
                    const d = await r.json();

                    if (!d.status) continue;

                    cache[id] = {
                        name,
                        until: d.status.until,
                        state: d.status.state,
                        t: now
                    };
                }

                const c = cache[id];
                if (c.state !== "Hospital") continue;

                const time = c.until - now;
                if (time <= 0) continue;

                output.push({ id, name, time });

            } catch {}
        }

        output.sort((a,b) => a.time - b.time);

        list.innerHTML = output.length ? output.map(o => `
            <div style="margin-bottom:6px;">
                <div style="display:flex;justify-content:space-between;">
                    <div>${o.name}</div>
                    <button data-id="${o.id}">CALL</button>
                </div>
                <div>${fmt(o.time)}</div>
            </div>
        `).join("") : `<div style="color:#aaa;">No targets</div>`;

        document.querySelectorAll("button[data-id]").forEach(btn => {
            btn.onclick = () => {
                const c = cache[btn.dataset.id];
                if (!c) return;
                navigator.clipboard.writeText(`${c.name} | ${fmt(c.until - now)}`);
            };
        });

        const hasReady = output.some(o => o.time < 360);
        setTimeout(loop, hasReady ? 2500 : 6000);
    }

    // ================= INIT =================
    loop();

})();
